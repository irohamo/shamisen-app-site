---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-wide site-footer__inner">
    <div class="site-footer__brand">
      <strong>ShamiScore</strong>
      <span>shamisen.app</span>
    </div>
    <nav class="site-footer__nav" aria-label="フッターナビゲーション">
      <ul>
        <li><a href="/support">サポート</a></li>
        <li><a href="/terms">利用規約</a></li>
        <li><a href="/privacy">プライバシーポリシー</a></li>
        <li><a href="mailto:support@shamisen.app">お問い合わせ</a></li>
      </ul>
    </nav>
    <p class="site-footer__copy">© {year} irohamo. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: #f4f0e7;
    padding: 2.5rem 0;
    margin-top: 4rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .site-footer__brand {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .site-footer__brand strong {
    color: var(--color-text);
    font-size: 1rem;
  }

  .site-footer__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }

  .site-footer__nav a {
    color: var(--color-text-muted);
  }

  .site-footer__nav a:hover {
    color: var(--color-accent);
  }

  .site-footer__copy {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>

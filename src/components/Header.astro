---
const navItems = [
  { href: '/', label: 'ホーム' },
  { href: '/support', label: 'サポート' },
  { href: '/terms', label: '利用規約' },
  { href: '/privacy', label: 'プライバシー' },
];
---

<header class="site-header">
  <div class="container-wide site-header__inner">
    <a href="/" class="site-header__brand" aria-label="ShamiScore ホーム">
      <img src="/appicon.png" alt="" width="36" height="36" />
      <span>ShamiScore</span>
    </a>
    <nav class="site-header__nav" aria-label="メインナビゲーション">
      <ul>
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: rgba(251, 249, 244, 0.85);
    backdrop-filter: saturate(140%) blur(8px);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    color: var(--color-text);
    font-size: 1.05rem;
    letter-spacing: 0.01em;
  }

  .site-header__brand:hover {
    text-decoration: none;
    color: var(--color-text);
  }

  .site-header__brand img {
    border-radius: 8px;
    display: block;
  }

  .site-header__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.25rem;
  }

  .site-header__nav a {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .site-header__nav a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
    }

    .site-header__nav ul {
      gap: 1rem;
      flex-wrap: wrap;
    }

    .site-header__nav a {
      font-size: 0.9rem;
    }
  }
</style>
